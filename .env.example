# Copy to .env.local for local dev, and set these in Vercel → Project → Settings → Environment Variables.
# The anon/publishable key is used by the API. The table's RLS policy allows
# INSERT only (no read), so this key cannot be used to read submissions.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_OR_PUBLISHABLE_KEY
